<style>
*{box-sizing:border-box;margin:0;padding:0}
.site{font-family:var(--font-sans);background:#fdf8f5;color:#3a2a22;min-height:600px;position:relative}
.header{background:#fff;border-bottom:0.5px solid #e8d5c8;padding:1.25rem 2rem;text-align:center}
.header-title{font-size:22px;font-weight:500;color:#a0522d;letter-spacing:0.04em}
.header-sub{font-size:13px;color:#c4836a;margin-top:3px}
.welcome-banner{background:#fceee8;border-bottom:0.5px solid #e8d5c8;padding:0.6rem 2rem;text-align:center;font-size:13px;color:#8b3a2a}
.nav{display:flex;background:#fff;border-bottom:0.5px solid #e8d5c8;overflow-x:auto}
.nav-btn{flex:1;min-width:80px;padding:0.8rem 0.5rem;font-size:13px;font-weight:500;color:#c4836a;background:none;border:none;border-bottom:2px solid transparent;cursor:pointer;transition:all .2s;white-space:nowrap;text-align:center}
.nav-btn.active{color:#a0522d;border-bottom:2px solid #c4836a;background:#fdf8f5}
.nav-btn:hover{background:#fceee8}
.section{display:none;padding:1.25rem 1.25rem 5rem}
.section.active{display:block}
.section-title{font-size:16px;font-weight:500;color:#a0522d;margin-bottom:1rem;padding-bottom:0.5rem;border-bottom:0.5px solid #e8d5c8}
.products{display:grid;grid-template-columns:repeat(auto-fill,minmax(150px,1fr));gap:0.9rem}
.card{background:#fff;border:0.5px solid #e8d5c8;border-radius:12px;padding:0.9rem;transition:border-color .2s}
.card:hover{border-color:#c4836a}
.card-icon{font-size:30px;text-align:center;margin-bottom:6px}
.card-name{font-size:15px;font-weight:700;color:#3a2a22;margin-bottom:3px}
.card-desc{font-size:13px;color:#3a2a22;margin-bottom:8px;line-height:1.4}
.card-price{font-size:13px;font-weight:600;color:#a0522d;margin-bottom:6px}
.add-btn{width:100%;background:#fceee8;color:#8b3a2a;border:0.5px solid #e8c0aa;border-radius:8px;padding:0.35rem;font-size:12px;cursor:pointer;font-weight:500;transition:all .2s}
.add-btn:hover{background:#c4836a;color:#fff;border-color:#c4836a}
.add-btn.added{background:#c4836a;color:#fff;border-color:#c4836a}
.float-cart{position:absolute;bottom:24px;right:20px;z-index:50;background:#c4836a;border:none;border-radius:50%;width:58px;height:58px;cursor:pointer;display:flex;align-items:center;justify-content:center;transition:background .2s}
.float-cart:hover{background:#a0522d}
.float-badge{position:absolute;top:-4px;right:-4px;background:#8b3a2a;color:#fff;border-radius:50%;width:20px;height:20px;font-size:11px;font-weight:500;display:flex;align-items:center;justify-content:center;display:none}
.float-badge.show{display:flex}
.drawer-overlay{display:none;position:absolute;top:0;left:0;right:0;bottom:0;background:rgba(58,42,34,0.3);z-index:60}
.drawer-overlay.open{display:block}
.drawer{position:absolute;right:0;top:0;bottom:0;width:300px;background:#fff;border-left:0.5px solid #e8d5c8;z-index:70;display:flex;flex-direction:column;transform:translateX(100%);transition:transform .25s}
.drawer.open{transform:translateX(0)}
.drawer-header{padding:1rem 1.25rem;border-bottom:0.5px solid #e8d5c8;display:flex;align-items:center;justify-content:space-between}
.drawer-title{font-size:15px;font-weight:500;color:#a0522d}
.drawer-close{background:none;border:none;font-size:20px;color:#c4836a;cursor:pointer;line-height:1}
.drawer-body{flex:1;overflow-y:auto;padding:1rem 1.25rem}
.cart-empty{text-align:center;color:#c4836a;padding:2rem 0;font-size:13px}
.cart-item{display:flex;align-items:center;justify-content:space-between;padding:0.6rem 0;border-bottom:0.5px solid #f0ddd4}
.cart-item-left{display:flex;align-items:center;gap:8px}
.cart-item-icon{font-size:20px}
.cart-item-name{font-size:13px;font-weight:500;color:#3a2a22}
.cart-item-price{font-size:12px;color:#9c6b5a}
.remove-btn{background:none;border:none;color:#e8c0aa;cursor:pointer;font-size:15px}
.remove-btn:hover{color:#c4836a}
.drawer-footer{padding:1rem 1.25rem;border-top:0.5px solid #e8d5c8}
.cart-total-row{display:flex;justify-content:space-between;font-size:14px;font-weight:500;color:#a0522d;margin-bottom:0.75rem}
.order-btn{width:100%;background:#c4836a;color:#fff;border:none;border-radius:8px;padding:0.75rem;font-size:14px;cursor:pointer;font-weight:500}
.order-btn:hover{background:#a0522d}
.modal-wrap{display:none;position:absolute;top:0;left:0;right:0;bottom:0;background:rgba(58,42,34,0.35);z-index:80;align-items:center;justify-content:center;min-height:600px}
.modal-wrap.open{display:flex}
.modal{background:#fff;border-radius:16px;border:0.5px solid #e8d5c8;padding:2rem 1.5rem;max-width:320px;width:90%;text-align:center}
.modal-icon{font-size:38px;margin-bottom:0.75rem}
.modal-title{font-size:17px;font-weight:500;color:#a0522d;margin-bottom:0.4rem}
.modal-sub{font-size:12px;color:#9c6b5a;margin-bottom:1.25rem;line-height:1.5}
.modal-items{text-align:left;background:#fdf8f5;border-radius:8px;padding:0.75rem 1rem;margin-bottom:1rem;font-size:12px;max-height:180px;overflow-y:auto}
.modal-item{display:flex;justify-content:space-between;padding:3px 0;color:#3a2a22}
.modal-divider{border:none;border-top:0.5px solid #e8d5c8;margin:6px 0}
.modal-total{font-weight:500;color:#a0522d}
.success-badge{display:inline-block;background:#eaf3de;color:#3b6d11;border-radius:20px;padding:0.4rem 1.25rem;font-size:13px;font-weight:500;margin-bottom:0.75rem}
.modal-close-btn{background:#c4836a;color:#fff;border:none;border-radius:8px;padding:0.55rem 1.5rem;font-size:13px;cursor:pointer;font-weight:500}
.modal-close-btn:hover{background:#a0522d}
</style>

<div class="site" id="app">
  <div class="header">
    <div class="header-title">Boutique de l'amour</div>
    <div class="header-sub">Un cadeau rien que pour toi</div>
  </div>
  <div class="welcome-banner">Bienvenue Louane ! Dans ta boutique surprise. Choisis tes cadeaux avec amour.</div>
  <div class="nav">
    <button class="nav-btn active" onclick="showTab('fleurs')">Fleurs</button>
    <button class="nav-btn" onclick="showTab('papeterie')">Papeterie</button>
    <button class="nav-btn" onclick="showTab('maquillage')">Maquillage</button>
    <button class="nav-btn" onclick="showTab('futur')">Futur</button>
  </div>

  <div id="section-fleurs" class="section active">
    <div class="section-title">Fleurs</div>
    <div class="products">
      <div class="card" style="background-image: linear-gradient(rgba(255,255,255,0.7), rgba(255,255,255,0.7)), url('roses.jpg')"><div class="card-icon">💐</div><div class="card-name">Bouquet de roses</div><div class="card-desc">12 roses rouges avec une surprise</div><div class="card-price">29.00 €</div><button class="add-btn" onclick="addToCart(this,'Bouquet de roses',29,'🌹')">Ajouter</button></div>
      <div class="card" style="background-image: linear-gradient(rgba(255,255,255,0.7), rgba(255,255,255,0.7)), url('roses.jpg')"><div class="card-icon">🌹</div><div class="card-name">Bouquet de roses</div><div class="card-desc">12 roses rouges sans surprise</div><div class="card-price">19.00 €</div><button class="add-btn" onclick="addToCart(this,'Bouquet de roses',19,'🌹')">Ajouter</button></div>
    </div>
  </div>

  <div id="section-papeterie" class="section">
    <div class="section-title">Papeterie</div>
    <div class="products">
      <div class="card" style="background-image: linear-gradient(rgba(255,255,255,0.7), rgba(255,255,255,0.7)), url('lettre.jpg'); background-repeat: no-repeat; background-size: 185%; background-position: center"> <div class="card-icon">💖</div><div class="card-name">Lettre d'amour</div><div class="card-desc">Lettre d'amour personnalisée</div><div class="card-price">5.49 €</div><button class="add-btn" onclick="addToCart(this,'Lettre d amour personnalisée',5.49,'💖')">Ajouter</button></div>
      <div class="card" style="background-image: linear-gradient(rgba(255,255,255,0.7), rgba(255,255,255,0.7)), url('bocal.jpg'); background-repeat: no-repeat; background-size: 140%; background-position: center"><div class="card-icon">🫙</div><div class="card-name">Bocal de mots</div><div class="card-desc">Mots doux, bocal inclut</div><div class="card-price">14.99 €</div><button class="add-btn" onclick="addToCart(this,'Bocal de mots',14.99,'🫙')">Ajouter</button></div>
    </div>
  </div>

  <div id="section-maquillage" class="section">
    <div class="section-title">Maquillage</div>
    <div class="products">
      <div class="card" style="background-image: linear-gradient(rgba(255,255,255,0.7), rgba(255,255,255,0.7)), url('ral.jpg'); background-repeat: no-repeat; background-size: 125%; background-position: center"><div class="card-icon">💄</div><div class="card-name">Rouge à lèvres mat</div><div class="card-desc">Article en magasin</div><div class="card-price">??? €</div><button class="add-btn" onclick="addToCart(this,'Rouge à lèvres mat',0,'💄')">Ajouter</button></div>
      <div class="card" style="background-image: linear-gradient(rgba(255,255,255,0.7), rgba(255,255,255,0.7)), url('blush.jpg'); background-repeat: no-repeat; background-size: 100%; background-position: center"><div class="card-icon">😊</div><div class="card-name">Blush</div><div class="card-desc">Article en magasin</div><div class="card-price">??? €</div><button class="add-btn" onclick="addToCart(this,'Blush',0,'😊')">Ajouter</button></div>
      <div class="card" style="background-image: linear-gradient(rgba(255,255,255,0.7), rgba(255,255,255,0.7)), url('masca.jpg'); background-repeat: no-repeat; background-size: 100%; background-position: center"><div class="card-icon">👝</div><div class="card-name">Mascara</div><div class="card-desc">Article en magasin</div><div class="card-price">??? €</div><button class="add-btn" onclick="addToCart(this,'Mascara',0,'👝')">Ajouter</button></div>
    </div>
  </div>

  <div id="section-futur" class="section">
    <div class="section-title">Futur</div>
    <div class="products">
      <div class="card"><div class="card-icon"><img src="https://flagcdn.com/w40/fr.png" width="30" alt="France"></div><div class="card-name">Semaine 1</div><div class="card-desc">Semaine 1</div><div class="card-price">Secret</div><button class="add-btn" onclick="addToCart(this,'Semaine 1',0,'https://flagcdn.com/w40/fr.png')">Ajouter</button></div>
      <div class="card"><div class="card-icon"><img src="https://flagcdn.com/w40/fr.png" width="30" alt="France"></div><div class="card-name">Semaine 2</div><div class="card-desc">Semaine 2</div><div class="card-price">Secret</div><button class="add-btn" onclick="addToCart(this,'Semaine 2',0,'https://flagcdn.com/w40/fr.png')">Ajouter</button></div>
      <div class="card"><div class="card-icon"><img src="https://flagcdn.com/w40/es.png" width="30" alt="Espagne"></div><div class="card-name">Semaine 3</div><div class="card-desc">Semaine 3</div><div class="card-price">Secret</div><button class="add-btn" onclick="addToCart(this,'Semaine 3',0,'https://flagcdn.com/w40/es.png')">Ajouter</button>
    </div>
  </div>
  
  <button class="float-cart" id="float-cart-btn" onclick="openDrawer()" title="Mon panier">
    <span id="float-badge" class="float-badge">0</span>
    <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="#fff" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/><path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"/></svg>
  </button>

  <div class="drawer-overlay" id="drawer-overlay" onclick="closeDrawer()"></div>
  <div class="drawer" id="drawer">
    <div class="drawer-header">
      <span class="drawer-title">Mon panier</span>
      <button class="drawer-close" onclick="closeDrawer()">×</button>
    </div>
    <div class="drawer-body" id="drawer-body"></div>
    <div class="drawer-footer" id="drawer-footer" style="display:none">
      <div class="cart-total-row"><span>Total</span><span id="drawer-total">0 €</span></div>
      <button class="order-btn" onclick="openModal()">Commander mes cadeaux</button>
    </div>
  </div>

  <div class="modal-wrap" id="modal-wrap">
    <div class="modal" id="modal-content"></div>
  </div>
</div>

<script>
var cart=[];
function showTab(t){
  var tabs=['fleurs','papeterie','maquillage','futur'];
  tabs.forEach(function(id){document.getElementById('section-'+id).classList.remove('active')});
  document.querySelectorAll('.nav-btn').forEach(function(b){b.classList.remove('active')});
  document.getElementById('section-'+t).classList.add('active');
  var idx=tabs.indexOf(t);
  document.querySelectorAll('.nav-btn')[idx].classList.add('active');
}
function addToCart(btn,name,price,icon){
  if(btn.classList.contains('added'))return;
  cart.push({name:name,price:price,icon:icon,id:Date.now()+Math.random()});
  btn.classList.add('added');btn.textContent='Ajouté !';
  updateBadge();
}
function updateBadge(){
  var b=document.getElementById('float-badge');
  b.textContent=cart.length;
  cart.length>0?b.classList.add('show'):b.classList.remove('show');
}
function openDrawer(){
  renderDrawer();
  document.getElementById('drawer-overlay').classList.add('open');
  document.getElementById('drawer').classList.add('open');
}
function closeDrawer(){
  document.getElementById('drawer-overlay').classList.remove('open');
  document.getElementById('drawer').classList.remove('open');
}
function renderDrawer(){
  var body=document.getElementById('drawer-body');
  var footer=document.getElementById('drawer-footer');
  if(cart.length===0){body.innerHTML='<div class="cart-empty">Ton panier est vide.<br>Choisis des cadeaux !</div>';footer.style.display='none';return}
  var html='';
  cart.forEach(function(item){
    html+='<div class="cart-item"><div class="cart-item-left"><img src="'+item.icon+'" width="25" style="margin-right:8px"><div><div class="cart-item-name">'+item.name+'</div><div class="cart-item-price">'+item.price+' €</div></div></div><button class="remove-btn" onclick="removeItem(\''+item.id+'\')">×</button></div>';
  body.innerHTML=html;
  var total=cart.reduce(function(s,i){return s+i.price},0);
  document.getElementById('drawer-total').textContent=total+' €';
  footer.style.display='block';
  });
}
function removeItem(id){
  var item=cart.find(function(i){return String(i.id)===String(id)});
  if(item){
    cart=cart.filter(function(i){return String(i.id)!==String(id)});
    document.querySelectorAll('.add-btn.added').forEach(function(b){
      if(b.closest('.card')&&b.closest('.card').querySelector('.card-name').textContent===item.name){
        b.classList.remove('added');b.textContent='Ajouter';
      }
    });
    updateBadge();renderDrawer();
  }
}
function openModal(){
  var total=cart.reduce(function(s,i){return s+i.price},0);
  var itemsHtml='';
  cart.forEach(function(item){itemsHtml+='<div class="modal-item"><span>'+item.icon+' '+item.name+'</span><span>'+item.price+' €</span></div>'});
  document.getElementById('modal-content').innerHTML='<div class="modal-icon">🎁</div><div class="modal-title">Récapitulatif de ta commande</div><div class="modal-sub">Voilà tout ce que vous avez choisi, Mme Bironneau !</div><div class="modal-items">'+itemsHtml+'<hr class="modal-divider"><div class="modal-item modal-total"><span>Total</span><span>'+total+' €</span></div></div><button class="modal-close-btn" onclick="showSuccess()">Valider ma commande</button>';
  document.getElementById('modal-wrap').classList.add('open');
}
function showSuccess(){
  document.getElementById('modal-content').innerHTML='<div class="modal-icon">💌</div><div class="success-badge">Commande réussie !</div><div class="modal-title">Merci Mme.Bironneau !</div><div class="modal-sub" style="margin-bottom:1.25rem">Ta commande a bien été prise en compte et transmis au maître suprême. Tes cadeaux arrivent très vite.</div><button class="modal-close-btn" onclick="closeModal()">Fermer</button>';
}
function closeModal(){document.getElementById('modal-wrap').classList.remove('open')}
</script>
